{
  "compilerOptions": {
    "target": "ES2023",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "composite": true,
    "outDir": "dist/node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["vite.config.ts", "playwright.config.ts", "e2e"]
}
