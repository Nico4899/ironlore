{
  "name": "@ironlore/electron",
  "version": "0.0.1",
  "private": true,
  "description": "Electron shell for Ironlore",
  "type": "module",
  "main": "dist/main.cjs",
  "scripts": {
    "build:main": "esbuild src/main.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/main.cjs --external:electron",
    "build:client": "pnpm --filter @ironlore/web build",
    "build": "pnpm build:client && pnpm build:main",
    "dev": "pnpm build:main && electron dist/main.cjs",
    "dist": "pnpm build && electron-builder --config electron-builder.yml",
    "dist:mac": "pnpm build && electron-builder --config electron-builder.yml --mac",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@ironlore/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0"
  }
}
