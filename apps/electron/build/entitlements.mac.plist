<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Electron + the spawned Hono server child. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- The renderer + main both need network for /api + /ws on
       localhost. Without `network.client` Gatekeeper can block
       even loopback connections under hardened runtime. -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
  <!-- node-pty spawns shells; sharp / better-sqlite3 are JIT'd
       native modules. `disable-library-validation` lets the
       Electron app load unsigned native deps shipped via
       extraResources / asarUnpack. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Apple's notarization service requires the inheritable
       entitlement on child processes the app spawns; the
       Hono server child must inherit network + library-validation
       relaxations or it dies on launch. -->
  <key>com.apple.security.inherit</key>
  <true/>
</dict>
</plist>
