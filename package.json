{
  "name": "ironlore",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @ironlore/web dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm --filter @ironlore/web test:e2e",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc -b"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
