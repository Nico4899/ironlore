{
  "name": "ironlore",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @ironlore/web dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm --filter @ironlore/web test:e2e",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc -b"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/papaparse": "^5.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.14.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.6.205"
  }
}
